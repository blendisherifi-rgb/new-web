<!-- 
  SoftCo Team Members — WordPress WXR Import File
  ================================================
  IMPORT STEPS:
  1. Register the `team_member` CPT in WordPress (see functions.php snippet below).
  2. Import `acf-export-team-member-cpt.json` via ACF → Tools → Import Field Groups.
  3. Go to WP Admin → Tools → Import → WordPress → Choose file → select this file.
  4. On the import screen, check "Download and import file attachments" so photos
     are pulled from softco.com into your media library automatically.
  5. After import, run the one-time ACF photo sync snippet below so the ACF `photo`
     field on each post is linked to the correct attachment.

  ── CPT REGISTRATION (add to functions.php or a plugin) ───────────────────────
  add_action('init', function() {
    register_post_type('team_member', [
      'label'               => 'Team Members',
      'public'              => true,
      'show_in_graphql'     => true,
      'graphql_single_name' => 'teamMember',
      'graphql_plural_name' => 'teamMembers',
      'supports'            => ['title', 'thumbnail'],
      'menu_icon'           => 'dashicons-groups',
      'has_archive'         => false,
      'rewrite'             => ['slug' => 'team'],
    ]);
  });

  ── ONE-TIME ACF PHOTO SYNC (run via Code Snippets plugin, then remove) ────────
  add_action('init', function() {
    if ( ! isset($_GET['sync_team_photos']) || ! current_user_can('manage_options') ) return;
    $posts = get_posts(['post_type' => 'team_member', 'posts_per_page' => -1, 'fields' => 'ids']);
    foreach ($posts as $id) {
      $thumb_id = get_post_thumbnail_id($id);
      if ($thumb_id) update_field('photo', $thumb_id, $id);
    }
    wp_die('Team member photos synced: ' . count($posts) . ' posts updated.');
  });
  // Then visit: https://your-site.com/?sync_team_photos=1
-->
